# =============================================================================
# POS System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=pos-system
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # true | false
SECRET_KEY=change-me-to-a-random-64-char-string

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_WORKERS=1                # Use 1 for dev, 4+ for production
LOG_LEVEL=debug                  # debug | info | warning | error
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8090

# -----------------------------------------------------------------------------
# Frontend (Vite + React)
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8090/api
VITE_WS_URL=ws://localhost:8090/ws

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5450
POSTGRES_DB=pos_system
POSTGRES_USER=pos_admin
POSTGRES_PASSWORD=localdev123
DATABASE_URL=postgresql+asyncpg://pos_admin:localdev123@postgres:5432/pos_system

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6390
REDIS_PASSWORD=pos_redis_dev_secret
REDIS_URL=redis://:pos_redis_dev_secret@redis:6379/0

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_PORT=8090
NGINX_SSL_PORT=8443

# -----------------------------------------------------------------------------
# QuickBooks Integration
# -----------------------------------------------------------------------------
# IMPORTANT: Intuit provides TWO credential types (same app, different tabs):
#   - DEVELOPMENT: Only connects to Intuit sandbox + whitelisted test users
#   - PRODUCTION:  Connects to ANY real QB company (customer OAuth)
#
# Usage Guide:
#   Local dev:        Development credentials + QB_ENVIRONMENT=sandbox
#   Staging/Prod:     Production credentials  + QB_ENVIRONMENT=production
#   Customer demos:   Production credentials  (real companies require this)
#
# Get credentials: https://developer.intuit.com → Keys & Credentials tab
QB_CLIENT_ID=                    # Paste from Intuit portal (document: DEV or PROD)
QB_CLIENT_SECRET=                # CRITICAL: Must match credential type above
QB_REDIRECT_URI=http://localhost:8090/api/v1/integrations/quickbooks/callback
QB_ENVIRONMENT=sandbox           # sandbox | production (API base URL)

# -----------------------------------------------------------------------------
# FBR / PRA Tax Integration (Pakistan)
# -----------------------------------------------------------------------------
FBR_POS_ID=
FBR_API_URL=https://fbr-api.gov.pk
PRA_POS_ID=
PRA_API_URL=https://pra-api.punjab.gov.pk

# -----------------------------------------------------------------------------
# Payment Gateway
# -----------------------------------------------------------------------------
PAYMENT_GATEWAY=stripe           # stripe | other
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
S3_BUCKET_NAME=
